{
  "$schema": "../gen/schemas/desktop-schema.json",
  "productName": "ezmm",
  "version": "0.1.0",
  "identifier": "com.ezmm.app",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "ezmm",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
